# Serava Governor Backend - Configuration Example

# App settings
APP_NAME="Serava Governor Backend"
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=1.1.0
DOCS_ENABLED=true

# Security
API_KEY_HEADER_NAME=X-API-Key
INTERNAL_API_KEY=your_internal_api_key_here

# CORS
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=*

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_SCHEMA=public
AUDIT_TABLE=governor_audit

# LLM Configuration
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL_TRANSLATE=gpt-4.1-mini
LLM_MODEL_CLARIFY=gpt-4.1-mini
LLM_MODEL_REFORMULATE=gpt-4.1-mini
LLM_MODEL_EXTRACT=gpt-4.1-mini
LLM_MODEL_GOVERNOR=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=45
LLM_TEMPERATURE=0.1
LLM_OPENROUTER_REFERER=
LLM_OPENROUTER_TITLE="Serava Governor Backend"

# Governor Logic
ALLOW_GOVERNOR_MUTATIONS=false
DEFAULT_CANONICAL_LANGUAGE=fr
DEFAULT_AUDIENCE=internal

# Documentary Engine
CHUNK_MAX_CHARS=3500
CHUNK_OVERLAP_CHARS=400
RETRIEVAL_DEFAULT_TOP_K=5

# Logging
REQUEST_LOG_PAYLOADS=true
