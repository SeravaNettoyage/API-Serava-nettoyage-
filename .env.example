APP_NAME=Serava Governor Backend
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=1.0.0
DOCS_ENABLED=true

API_KEY_HEADER_NAME=X-API-Key
INTERNAL_API_KEY=

CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=*

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SCHEMA=public
AUDIT_TABLE=governor_audit

LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL_TRANSLATE=qwen/qwen3-32b:free
LLM_MODEL_CLARIFY=qwen/qwen3-32b:free
LLM_MODEL_REFORMULATE=qwen/qwen3-32b:free
LLM_TIMEOUT_SECONDS=45
LLM_TEMPERATURE=0.1
LLM_OPENROUTER_REFERER=
LLM_OPENROUTER_TITLE=Serava Governor Backend

ALLOW_GOVERNOR_MUTATIONS=false
DEFAULT_CANONICAL_LANGUAGE=fr
DEFAULT_AUDIENCE=internal

REQUEST_LOG_PAYLOADS=true
